{
    "parentMode": "user",
    "colorScheme": "prefer-@DefaultVariant@",
    "stylesheetName": "@ThemeName@/gnome-shell.css",
    "themeResourceName": "@ThemeResourcePath@gnome-shell-theme.gresource",
    "iconsResourceName": "@ThemeResourcePath@gnome-shell-icons.gresource",
    "debugFlags": ["backtrace-crashes-all"],
    "enabledExtensions": [
        "ubuntu-dock@ubuntu.com",
        "ubuntu-appindicators@ubuntu.com",
        "ding@rastersoft.com",
        "tiling-assistant@ubuntu.com",
        "snapd-prompting@canonical.com",
        "snapd-search-provider@canonical.com",
        "web-search-provider@ubuntu.com"
    ]
}